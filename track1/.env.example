NODE_ENV=production
PORT=3000

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nevup
DB_USER=nevup
DB_PASSWORD=nevup_secret

# RabbitMQ
RABBITMQ_URL=amqp://nevup:nevup_secret@rabbitmq:5672

# JWT - Set via environment variable, required for all tracks
# Get the secret from the hackathon kickoff email
JWT_SECRET=your_jwt_secret_here
